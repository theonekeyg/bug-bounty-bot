generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Session {
  id           String   @id @default(cuid())
  target       String
  briefPath    String
  briefContent String
  model        String
  boxerUrl     String
  maxTracks    Int      @default(6)
  status       String   @default("running") // running | completed | failed | crashed
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  completedAt  DateTime?
  tracks       Track[]
  events       EventRecord[]
}

model Track {
  id            String   @id
  sessionId     String
  session       Session  @relation(fields: [sessionId], references: [id])
  hypothesis    String
  status        String   @default("running") // running | found | disproven | blocked | awaiting_permission
  workspaceId   String?
  blockedReason String?
  startedAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model EventRecord {
  id        String   @id @default(cuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id])
  trackId   String?
  kind      String
  severity  String
  title     String
  detail    String?
  stage     String?
  status    String?
  createdAt DateTime @default(now())
}

model AgentTurn {
  id               String     @id @default(cuid())
  sessionId        String
  trackId          String
  iteration        Int
  turnIndex        Int
  thinkingText     String     @default("")
  textOutput       String     @default("")
  inputTokens      Int        @default(0)
  outputTokens     Int        @default(0)
  cacheReadTokens  Int        @default(0)
  cacheWriteTokens Int        @default(0)
  startedAt        DateTime   @default(now())
  completedAt      DateTime?
  toolCalls        ToolCall[]

  @@index([sessionId, trackId])
}

model ToolCall {
  id          String     @id @default(cuid())
  turnId      String
  turn        AgentTurn  @relation(fields: [turnId], references: [id])
  toolUseId   String     @unique
  toolName    String
  toolInput   String     @default("")
  toolOutput  String     @default("")
  outcome     String     @default("pending")
  elapsedMs   Int        @default(0)
  startedAt   DateTime   @default(now())
  completedAt DateTime?
}
